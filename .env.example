# Copy this file to ".env" and fill in your real keys.
# NEVER commit the real .env file to GitHub.

# Required: Groq API key -> https://console.groq.com/keys  (free)
GROQ_API_KEY=your_groq_api_key_here

# Optional: which Groq model to use (default: llama-3.3-70b-versatile)
# Other options: llama-3.1-8b-instant, openai/gpt-oss-120b, qwen/qwen3-32b
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: USDA FoodData Central key -> https://fdc.nal.usda.gov/api-key-signup.html
# If left as DEMO_KEY it still works but is heavily rate-limited.
USDA_API_KEY=DEMO_KEY
